t.ylabel('Accuracy')\n","plt.ylim([min(plt.ylim()),1])\n","plt.title('Training and Validation Accuracy')\n","\n","plt.subplot(1, 2, 2)\n","plt.plot(loss, label='Training Loss')\n","plt.plot(val_loss, label='Validation Loss')\n","plt.legend(loc='upper right')\n","plt.ylabel('Cross Entropy')\n","plt.ylim([0,max(plt.ylim())])\n","plt.title('Training and Validation Loss')\n","plt.show()\n","\n","# --- Generate predictions for Confusion Matrix and per-class accuracy ---\n","val_labels = []\n","val_predictions = []\n","\n","for images, labels in val_ds:\n","    predictions = model.predict(images)\n","    val_predictions.extend(np.argmax(predictions, axis=1))\n","    val_labels.extend(labels.numpy())\n","\n","# --- Create and display Confusion Matrix ---\n","cm = confusion_matrix(val_labels, val_predictions)\n","plt.figure(figsize=(8, 8))\n","disp = ConfusionMatrixDisplay(confusion_matrix=cm, display_labels=class_names)\n","disp.plot(cmap=plt.cm.Blues)\n","plt.title('Confusion Matrix')\n","plt.show()\n","\n","# --- Calculate and display per-class accuracy ---\n","per_class_accuracy = {}\n","for i, class_name in enumerate(class_names):\n","    true_positives = np.sum((np.array(val_labels) == i) & (np.array(val_predictions) == i))\n","    total_in_class = np.sum(np.array(val_labels) == i)\n","    if total_in_class > 0:\n","        accuracy = true_positives / total_in_class\n","        per_class_accuracy[class_name] = accuracy\n","    else:\n","        per_class_accuracy[class_name] = 0.0\n","\n","print(\"\\nSamlad statistik för accuracyn för varje etikett:\")\n","for class_name, accuracy in per_class_accuracy.items():\n","    print(f\"{class_name}: {accuracy:.4f}\")\n","\n","print(\"Model training analysis complete. Halting as requested by 'Stoppa sedan'.\")"],"execution_count":10,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1200x400 with 2 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"stream","name":"stdout","text":["\u001b[1m1/1\u