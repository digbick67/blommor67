\"Unpacking images from {zip_path}...\")\n","    with zipfile.ZipFile(zip_path, 'r') as zip_ref:\n","        zip_ref.extractall(extract_dir)\n","    print(\"Images unpacked successfully.\")\n","\n","    # --- 2. Iterate through unpacked images, predict, and display ---\n","    image_paths = []\n","    for root, _, files in os.walk(extract_dir):\n","        for file in files:\n","            if file.lower().endswith(('.png', '.jpg', '.jpeg')):\n","                image_paths.append(os.path.join(root, file))\n","\n","    if not image_paths:\n","        print(f\"No image files found in '{extract_dir}'.\")\n","    else:\n","        print(f\"Found {len(image_paths)} images for prediction.\")\n","        plt.figure(figsize=(15, 10)) # Adjust figure size for better display\n","\n","        for i, img_path in enumerate(image_paths):\n","            print(f\"Processing image: {img_path}\")\n","            # Load the image\n","            img = tf.keras.utils.load_img(img_path, target_size=IMG_SIZE)\n","            img_array = tf.keras.utils.img_to_array(img)\n","            img_array = np.expand_dims(img_array, axis=0) # Create a batch\n","\n","            # Preprocess the image for MobileNetV2\n","            # MobileNetV2 expects input normalized in the [-1, 1] range.\n","            preprocessed_img = tf.keras.applications.mobilenet_v2.preprocess_input(img_array)\n","\n","            # Make a prediction\n","            predictions = model.predict(preprocessed_img)\n","            softmax_predictions = tf.nn.softmax(predictions[0]) # Apply softmax to get probabilities if not already applied by model\n","\n","            predicted_class_index = np.argmax(softmax_predictions)\n","            predicted_probability = softmax_predictions[predicted_class_index].numpy()\n","            predicted_class_name = class_names[predicted_class_index]\n","\n","            # Determine certainty\n","            certainty = \"safe\" if predicted_probability > 0.75 else \"uncertain\"\n","\n","            # Display the image and prediction\n","            plt.subplot(len(image_paths) // 3 + 1, 3, i + 1) # Adjust subplot grid dynamically\n","            plt.imshow(img)\n","            plt.title(f\"Pred: {predicted_class_name}\\nProb: {predicted_probability:.2f} ({certainty})\")\n","            plt.axis(\"off\")\n","\n","        plt.tight_layout()\n","        plt.show()\n","\n","    # Clean up the extracted images directory\n","    # import shutil\n","    # shutil.rmtree(extract_dir)\n","    # print(f\"Cleaned up extraction directory: {extract_dir}\")\n","\n","print(\"\\nImage prediction and display process complete.\")\n","```"]},{"cell_type":"markdown","metadata":{"id":"a69c40f0"},"source":["## unzip_predict_display_images\n","\n","### Subtask:\n","Unpack images from 'blomtester.zip', display each image, and show the model's prediction, probability, and certainty (safe if probability > 0.75, otherwise uncertain).\n"]},{"cell_type":"markdown","metadata":{"id":"fca60449"},"source":["## Summary:\n","\n","### Data Analysis Key Findings\n","\n","*   A total of 6 test images from the `blomtester.zip` file were extracted and processed for evaluation.\n","*   For each of these images, the trained model provided a prediction including the predicted class name, the associated probability, and a certainty indicator.\n","*   The certainty indicator classified a prediction as \"safe\" if its probability exceeded 0.75, otherwise, it was labeled as \"uncertain.\"\n","*   The predictions for all images were visually presented, displaying the image along with its predicted class, probability, and certainty.\n","\n","### Insights or Next Steps\n","\n","*   Review the displayed predictions for all 6 test images to qualitatively assess the model's performance, paying close attention to any \"uncertain\" classifications or obvious misclassifications to identify areas for model improvement.\n","*   Consider calculating aggregate metrics (e.g., accuracy, precision, recall) ove